# Railway Postgres provides DATABASE_URL automatically when you link the database service.
DATABASE_URL="postgresql://postgres:password@localhost:5432/team_task_manager?schema=public"

JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Railway sets PORT automatically — do not hardcode in production.
PORT=5000

# Your deployed frontend URL (no trailing slash). Comma-separate for multiple origins.
FRONTEND_URL="http://localhost:5173,https://ethanaai-task-manager-frontend-production.up.railway.app"
